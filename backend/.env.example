# Environment template for Django backend.
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC
DATABASE_URL=
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
STATIC_URL=
MEDIA_URL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
CORS_ALLOW_ALL_ORIGINS=True

# Database switch
USE_SQLITE=True
SQLITE_PATH=db.sqlite3

# PostgreSQL (used when USE_SQLITE=False)
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=calm_table
DATABASE_USER=calm_table
DATABASE_PASSWORD=calm_table
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Reservation behavior
MAX_RESERVATIONS_PER_SLOT=3
RESERVATION_TIME_SLOTS=17:00,17:30,18:00,18:30,19:00,19:30,20:00,20:30,21:00

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email
DEFAULT_FROM_EMAIL=no-reply@calmtable.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SITE_BASE_URL=http://localhost
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd

# Celery execution
CELERY_TASK_ALWAYS_EAGER=False

# Admin bootstrap (dev convenience)
CREATE_SUPERUSER=True
DJANGO_SUPERUSER_USERNAME=admin@calmtable.mw
DJANGO_SUPERUSER_EMAIL=admin@calmtable.mw
DJANGO_SUPERUSER_PASSWORD=password123
